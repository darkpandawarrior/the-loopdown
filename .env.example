# The Loopdown — secrets. Copy to `.env` (gitignored) and fill what you have.
# FREE-ONLY setup. You never commit .env. See SETUP.md for how to get each.
# Readiness: `node scripts/check-setup.mjs`
#
# ── The free pipeline ──────────────────────────────────────────────────────
#   dev.to     → FULL auto-publish (free API)          ← the only token you truly need
#   LinkedIn   → paste out/linkedin.txt (free)
#   Medium     → auto IF your account has a legacy token (free), else paste/import
#   Hashnode   → import from the dev.to URL (free; API publish needs Pro — skipped)
# ───────────────────────────────────────────────────────────────────────────

# --- dev.to (Forem) — FREE, full automation. The one that matters. ---
# Settings → Extensions → "DEV Community API Keys" → Generate.  (header: api-key)
DEVTO_API_KEY=

# --- Medium — FREE if your account can still mint a legacy integration token ---
# medium.com → Settings → Security and apps → Integration tokens. If it's there, use it;
# if not, leave blank and import from the dev.to URL (one click). check-setup prints your id.
MEDIUM_TOKEN=
MEDIUM_USER_ID=

# --- Cover images — FREE (after you push the repo public) ---
# https://raw.githubusercontent.com/darkpandawarrior/the-loopdown/main
GITHUB_ASSET_BASE_URL=

# --- Canonical home (SEO) — FREE, optional. Default (profile.yaml) = dev.to is canonical. ---
# To own the SEO with your site: https://darkpandawarrior.github.io/the-loopdown  (slug appended)
CANONICAL_BASE_URL=

# ── NOT needed for the free setup (leave blank) ───────────────────────────
# Hashnode API publish requires Hashnode Pro — free path imports from dev.to instead.
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=
# Buffer just auto-queues LinkedIn; free path is pasting out/linkedin.txt yourself.
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=
