# The Loopdown — secrets. Copy to `.env` (gitignored) and fill what you have.
# The pipeline lights up per-token: `node scripts/check-setup.mjs` shows readiness.
# You NEVER commit .env. Nothing here is shared. See SETUP.md for how to get each.

# --- dev.to (Forem) — true automation, easiest to get ---
# Settings → Extensions → "DEV Community API Keys" → Generate.  (header: api-key)
DEVTO_API_KEY=

# --- Hashnode — true automation. NOTE: publish API needs Hashnode Pro (since 2026-05-13) ---
# Token: hashnode.com/settings/developer → Generate New Token.
HASHNODE_TOKEN=
# Your publication id: run `node scripts/check-setup.mjs` after setting the token —
# it queries and prints your publication ids for you to paste here.
HASHNODE_PUBLICATION_ID=

# --- Buffer (LinkedIn scheduling) — OPTIONAL. Requires a Buffer developer app. ---
# buffer.com/developers/apps → create app → access token. Profile id from the API.
# If blank, LinkedIn falls back to a paste-ready export (recommended to start).
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=

# --- Cover images ---
# Public base URL where a lesson's card.png is reachable, used as the article cover.
# After you push to GitHub:  https://raw.githubusercontent.com/darkpandawarrior/the-loopdown/main
GITHUB_ASSET_BASE_URL=

# --- Medium: no key. API is deprecated; export produces a paste-ready file. ---
